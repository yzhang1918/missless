{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": "../..",
    "paths": {
      "@missless/contracts": ["packages/contracts/src/index.ts"],
      "@missless/core": ["packages/core/src/index.ts"],
      "@missless/rendering": ["packages/rendering/src/index.ts"]
    }
  },
  "references": [
    {
      "path": "../../packages/contracts"
    },
    {
      "path": "../../packages/core"
    },
    {
      "path": "../../packages/rendering"
    }
  ],
  "include": ["src/**/*.ts"]
}
